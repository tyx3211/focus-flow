{
  "name": "focus-flow",
  "version": "1.1.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:backend": "cd backend && cargo build --release",
    "build": "npm run build:backend && vue-tsc && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.18",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "vite-plugin-electron": "^0.28.3",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.focusflow.monitor",
    "productName": "Focus Flow",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "backend/target/release/focus-flow-backend.exe",
        "to": "backend/focus-flow-backend.exe"
      }
    ]
  }
}
